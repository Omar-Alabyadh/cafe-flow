# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Cursor
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# local debug / temp artifacts
~$*
*.log
*.tmp
tmp/
.cursor/*.log
docs/thesis/tools/mermaid-renderer/.cache/

# Prisma local databases
prisma/*.db
prisma/*.db-journal
prisma/*.sqlite
prisma/*.sqlite-journal
